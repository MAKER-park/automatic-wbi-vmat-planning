# Data and model pipeline (paths may be absolute or repository-relative)
WBI_DATA_ROOT=./data
WBI_OUTPUT_ROOT=./outputs
WBI_PREDICTION_ROOT=./outputs/predictions
WBI_DICOM_INPUT_ROOT=./data/dicom
WBI_DICOM_OUTPUT_ROOT=./outputs/dicom

# RTDOSE identity handling. Keep true for research exports.
WBI_ANONYMIZE_DICOM=true
WBI_ANONYMIZED_NAME=ANONYMOUS
WBI_ANONYMIZED_ID=
WBI_COPY_SOURCE_DICOM=false

# RayStation workstation/site configuration
WBI_EXPORT_ROOT=C:\WBI_exports
WBI_RAYSTATION_MACHINE=YOUR_COMMISSIONED_MACHINE
WBI_RAYSTATION_IMAGING_SYSTEM=YOUR_IMAGING_SYSTEM
WBI_CLINICAL_GOAL_TEMPLATE=YOUR_CLINICAL_GOAL_TEMPLATE
WBI_ANGLE_CONFIG=C:\WBI_config\angles.json

# Privacy defaults. Set true only inside an approved clinical environment.
WBI_RAYSTATION_ANONYMIZE=true
WBI_LOG_PATIENT_IDENTIFIERS=false
